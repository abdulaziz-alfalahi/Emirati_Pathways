# ================================================
# Emirati Journey API — Moro Production Environment
# ================================================
# SECURITY NOTE: This is a TEMPLATE. Copy to .env.moro and fill in secrets.
# NEVER commit .env.moro to Git — it contains real credentials.
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(64))"

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false
PORT=5005

# Database Configuration — Moro PostgreSQL 18.3 EDB
DB_HOST=10.228.145.66
DB_PORT=5454
DB_NAME=dghr_prod
DB_USER=dghr_prod
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://dghr_prod:CHANGE_ME@10.228.145.66:5454/dghr_prod
USE_POSTGRESQL=true
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# Redis Configuration (with authentication)
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
USE_REDIS=true

# Security — MUST generate strong keys before production
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_STRONG_KEY
ENCRYPTION_KEY=CHANGE_ME_GENERATE_STRONG_KEY
SECURE_COOKIES=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# CORS — Update with actual domain/VIP when assigned
CORS_ORIGINS=https://emirati.ehrdc.gov.ae,http://emirati.ehrdc.gov.ae
ALLOWED_ORIGINS=https://emirati.ehrdc.gov.ae,http://emirati.ehrdc.gov.ae,http://10.228.145.3,http://10.228.145.6

# Auth
DISABLE_EMAIL_VERIFICATION=true
ALLOW_SIMPLE_REGISTRATION=true

# AI Service Configuration
DASHSCOPE_API_KEY=CHANGE_ME
DEFAULT_AI_PROVIDER=dashscope-qwen
GEMINI_API_KEY=CHANGE_ME

# UAE Localization
TIMEZONE=Asia/Dubai
LOCALE=en_AE
CURRENCY=AED

# Twilio WhatsApp (optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Compliance
DATA_RESIDENCY=UAE
GDPR_COMPLIANCE=true
UAE_DATA_PROTECTION_COMPLIANCE=true
AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=2555

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
