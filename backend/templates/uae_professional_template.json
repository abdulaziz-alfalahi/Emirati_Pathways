            "font_weight": "bold",
            "color": "#1B4F72",
            "margin_bottom": "10px"
          }
        },
        {
          "name": "professional_title",
          "type": "text",
          "required": false,
          "style": {
            "font_size": "16px",
            "color": "#34495E",
            "font_style": "italic",
            "margin_bottom": "15px"
          }
        },
        {
          "name": "contact_info",
          "type": "contact_group",
          "required": true,
          "style": {
            "font_size": "12px",
            "color": "#34495E",
            "display": "flex",
            "justify_content": "center",
            "gap": "20px"
          },
          "subfields": [
            {
              "name": "email",
              "type": "email",
              "required": true,
              "icon": "envelope"
