REDIS_URL=redis://localhost:6379
USE_REDIS=true
PORT=5003
FLASK_ENV=production
JWT_SECRET_KEY=your-jwt-secret-here
GEMINI_API_KEY=your-gemini-api-key-here
DEFAULT_AI_PROVIDER=google-gemini
DATABASE_URL=postgresql://emirati_user:emirati_secure_password@localhost/emirati_journey
USE_POSTGRESQL=true
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
ENCRYPTION_KEY=your-encryption-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:5003
DISABLE_EMAIL_VERIFICATION=true
ALLOW_SIMPLE_REGISTRATION=true
