// Relationships
Ref: admin_audit_log.user_id > users.id
Ref: admin_notifications.target_user_id > users.id
Ref: admin_roles.created_by > users.id
Ref: admin_settings.updated_by > users.id
Ref: admin_user_roles.user_id > users.id
Ref: admin_user_roles.role_id > admin_roles.id
Ref: admin_user_roles.assigned_by > users.id
Ref: admin_user_sessions.user_id > users.id
Ref: analytics_events.user_id > users.id
Ref: application_documents.uploaded_by > users.id
Ref: application_feedback.provided_by > users.id
Ref: application_notifications.user_id > users.id
Ref: application_status_history.changed_by > users.id
Ref: approval_requests.company_id > companies.id
Ref: approval_requests.requested_by > users.id
Ref: approval_requests.approver_id > users.id
Ref: attendance.student_id > students.id
Ref: attendance.class_id > classes.id
Ref: attendance.marked_by > users.id
Ref: candidate_assessments.profile_id > candidate_profiles.id
Ref: candidate_certifications.profile_id > candidate_profiles.id
Ref: candidate_education_entries.profile_id > candidate_profiles.id
Ref: candidate_experience_entries.profile_id > candidate_profiles.id
Ref: candidate_skills.profile_id > candidate_profiles.id
Ref: career_development_plans.mentee_user_id > users.id
Ref: career_development_plans.mentor_id > mentor_profiles.id
Ref: classes.educator_id > users.id
Ref: classes.institution_id > educational_institutions.id
Ref: cms_categories.parent_id > cms_categories.id
Ref: cms_content.created_by > users.id
Ref: cms_content.updated_by > users.id
Ref: cms_content_media.content_id > cms_content.id
Ref: cms_content_media.media_id > cms_media.id
Ref: cms_content_versions.content_id > cms_content.id
Ref: cms_content_versions.created_by > users.id
Ref: cms_content_workflows.content_id > cms_content.id
Ref: cms_content_workflows.workflow_id > cms_workflows.id
Ref: cms_content_workflows.assigned_to > users.id
Ref: cms_media.uploaded_by > users.id
Ref: cms_workflows.created_by > users.id
Ref: company_settings.company_id > companies.id
Ref: company_team_members.company_id > companies.id
Ref: company_team_members.user_id > users.id
Ref: company_team_members.invited_by > users.id
Ref: conversation_participants.conversation_id > conversations.id
Ref: course_assessments.course_id > courses.id
Ref: course_assessments.module_id > course_modules.id
Ref: course_certificates.enrollment_id > course_enrollments.id
Ref: course_enrollments.course_id > courses.id
Ref: course_enrollments.student_user_id > users.id
Ref: course_modules.course_id > courses.id
Ref: courses.institution_id > educational_institutions.id
Ref: courses.educator_id > educator_profiles.id
Ref: cv_analytics.cv_id > user_cvs.id
Ref: cv_profiles.user_id > users.id
Ref: cv_versions.cv_id > user_cvs.id
Ref: educator_analytics.educator_id > educator_profiles.id
