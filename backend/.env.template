# ==============================================================
# Dubai Human Development Platform — Backend Environment Template
# ==============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# NEVER commit the .env file to version control.
# ==============================================================

# --- Server ---
PORT=5005
FLASK_ENV=development          # development | production
FLASK_DEBUG=true               # true | false

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/emirati_journey
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=emirati_journey
DB_USER=<your_db_user>
DB_PASSWORD=<your_db_password>
USE_POSTGRESQL=true
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# --- Redis ---
REDIS_URL=redis://localhost:6379
USE_REDIS=false                # Set to true in production

# --- Security (ROTATE BEFORE PRODUCTION) ---
JWT_SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_hex(64))">
ENCRYPTION_KEY=<generate: python -c "import secrets; print(secrets.token_hex(32))">

# --- CORS ---
CORS_ORIGINS=http://localhost:8089,http://localhost:3000

# --- AI Services ---
DEFAULT_AI_PROVIDER=google-gemini
GEMINI_API_KEY=<your_gemini_api_key>
# GROQ_API_KEY=<optional>
# OPENAI_API_KEY=<optional>

# --- Twilio (WhatsApp OTP) ---
TWILIO_ACCOUNT_SID=<your_twilio_sid>
TWILIO_AUTH_TOKEN=<your_twilio_token>
TWILIO_FROM_NUMBER=whatsapp:+<your_number>

# --- Feature Flags ---
DISABLE_EMAIL_VERIFICATION=true
ALLOW_SIMPLE_REGISTRATION=true

# --- Object Storage (Production) ---
# STORAGE_TYPE=s3               # local | s3
# STORAGE_BUCKET=<bucket_name>
# STORAGE_REGION=me-south-1
# STORAGE_ACCESS_KEY=<key>
# STORAGE_SECRET_KEY=<secret>
# STORAGE_ENDPOINT=<endpoint_url>

# --- Monitoring (Production) ---
# SENTRY_DSN=<your_sentry_dsn>
# NEW_RELIC_LICENSE_KEY=<key>
