# Emirati Journey API - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# AI Service Configuration
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_SECRET_KEY=your_flask_secret_key_here

# Database Configuration (for production)
DATABASE_URL=postgresql://username:password@localhost:5432/emirati_journey
REDIS_URL=redis://localhost:6379/0

# Moro Hub Configuration
MORO_HUB_ENDPOINT=https://api.morohub.com
MORO_HUB_API_KEY=your_moro_hub_api_key_here
MORO_HUB_PROJECT_ID=your_project_id_here

# Security Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# Monitoring and Logging
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_here

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

