# ═══════════════════════════════════════════════════════════
# Qwen / DashScope Configuration
# Emirati Journey Platform — Qwen Migration
# ═══════════════════════════════════════════════════════════

# Required: Your DashScope API key
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# DashScope OpenAI-compatible endpoint
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model routing (override defaults)
# QWEN_PARSE_MODEL=qwen-turbo
# QWEN_MATCH_MODEL=qwen-plus

# Request settings
# QWEN_TIMEOUT=30
# QWEN_MAX_RETRIES=3
# QWEN_MAX_INPUT_CHARS=20000

# Logging
LOG_LEVEL=INFO
