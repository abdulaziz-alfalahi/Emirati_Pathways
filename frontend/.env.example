# Emirati Journey Platform - Frontend Environment Configuration
# Installation Location: emirati-journey-platform/.env.example
# Copy this file to .env and update the values

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API URL (for main API)
VITE_API_URL=http://localhost:5002

# Backend API Base URL (for recruiter services and Flask backend)
# This is used by the centralized API client
VITE_API_BASE_URL=http://localhost:5003

# WebSocket URL for real-time updates
VITE_WS_URL=ws://localhost:5002

# API Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# ============================================================================
# ANALYTICS CONFIGURATION
# ============================================================================

# Enable/disable analytics
VITE_ANALYTICS_ENABLED=true

# Enable real-time analytics updates
VITE_REAL_TIME_ANALYTICS=true

# Enable WebSocket for live updates
VITE_WEBSOCKET_ENABLED=true

# Enable UAE-specific analytics
VITE_UAE_ANALYTICS_ENABLED=true

# Enable performance monitoring
VITE_PERFORMANCE_MONITORING=true

# Enable error tracking
VITE_ERROR_TRACKING=true

# Analytics debug mode (development only)
VITE_ANALYTICS_DEBUG=true

# Default analytics time window
VITE_DEFAULT_TIME_WINDOW=1h

# Analytics refresh interval (milliseconds)
VITE_ANALYTICS_REFRESH_INTERVAL=30000

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application environment
VITE_ENVIRONMENT=development

# Application version
VITE_APP_VERSION=1.0.0

# Application name
VITE_APP_NAME=Emirati Journey Platform

# Default language
VITE_DEFAULT_LANGUAGE=en

# Supported languages
VITE_SUPPORTED_LANGUAGES=en,ar

# Enable RTL support
VITE_RTL_SUPPORT=true

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable CV builder
VITE_FEATURE_CV_BUILDER=true

# Enable job matching
VITE_FEATURE_JOB_MATCHING=true

# Enable analytics dashboard
VITE_FEATURE_ANALYTICS_DASHBOARD=true

# Enable UAE-specific features
VITE_FEATURE_UAE_SPECIFIC=true

# Enable real-time notifications
VITE_FEATURE_REAL_TIME_NOTIFICATIONS=true

# Enable data export
VITE_FEATURE_DATA_EXPORT=true

# Enable advanced reporting
VITE_FEATURE_ADVANCED_REPORTING=true

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# JWT token storage (localStorage or sessionStorage)
VITE_TOKEN_STORAGE=localStorage

# Session timeout (minutes)
VITE_SESSION_TIMEOUT=60

# Enable CSRF protection
VITE_CSRF_PROTECTION=true

# ============================================================================
# UI/UX CONFIGURATION
# ============================================================================

# Theme mode (light, dark, auto)
VITE_THEME_MODE=auto

# Enable animations
VITE_ANIMATIONS_ENABLED=true

# Page size for pagination
VITE_DEFAULT_PAGE_SIZE=20

# Maximum file upload size (MB)
VITE_MAX_FILE_SIZE=10

# Supported file types for CV upload
VITE_SUPPORTED_CV_TYPES=pdf,doc,docx

# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================

# Enable React Query DevTools
VITE_REACT_QUERY_DEVTOOLS=true

# Enable Redux DevTools
VITE_REDUX_DEVTOOLS=true

# Enable console logging
VITE_CONSOLE_LOGGING=true

# Enable source maps
VITE_SOURCE_MAPS=true

# ============================================================================
# PRODUCTION CONFIGURATION (for .env.production)
# ============================================================================

# Production API URL
# VITE_API_URL=https://api.emiratijourney.ae

# Production WebSocket URL
# VITE_WS_URL=wss://api.emiratijourney.ae

# Disable debug features in production
# VITE_ANALYTICS_DEBUG=false
# VITE_REACT_QUERY_DEVTOOLS=false
# VITE_REDUX_DEVTOOLS=false
# VITE_CONSOLE_LOGGING=false
# VITE_SOURCE_MAPS=false

# ============================================================================
# ANALYTICS PROVIDERS (Optional)
# ============================================================================

# Google Analytics ID (if using)
# VITE_GA_TRACKING_ID=

# Mixpanel Token (if using)
# VITE_MIXPANEL_TOKEN=

# Hotjar ID (if using)
# VITE_HOTJAR_ID=

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Map provider API key (for location features)
# VITE_MAP_API_KEY=

# File storage service
# VITE_STORAGE_SERVICE=local

# CDN URL for assets
# VITE_CDN_URL=

# ============================================================================
# MONITORING AND LOGGING
# ============================================================================

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=

# LogRocket App ID
# VITE_LOGROCKET_APP_ID=

# Enable performance monitoring
VITE_PERFORMANCE_MONITORING=true

# ============================================================================
# LOCALIZATION
# ============================================================================

# Translation service API key
# VITE_TRANSLATION_API_KEY=

# Default currency
VITE_DEFAULT_CURRENCY=AED

# Default timezone
VITE_DEFAULT_TIMEZONE=Asia/Dubai

# Date format
VITE_DATE_FORMAT=DD/MM/YYYY

# Time format
VITE_TIME_FORMAT=HH:mm

# ============================================================================
# ACCESSIBILITY
# ============================================================================

# Enable accessibility features
VITE_ACCESSIBILITY_ENABLED=true

# Enable screen reader support
VITE_SCREEN_READER_SUPPORT=true

# Enable keyboard navigation
VITE_KEYBOARD_NAVIGATION=true

# High contrast mode support
VITE_HIGH_CONTRAST_SUPPORT=true

# ============================================================================
# CACHING
# ============================================================================

# Enable service worker
VITE_SERVICE_WORKER_ENABLED=true

# Cache strategy (networkFirst, cacheFirst, staleWhileRevalidate)
VITE_CACHE_STRATEGY=staleWhileRevalidate

# Cache duration (hours)
VITE_CACHE_DURATION=24

# ============================================================================
# NOTES
# ============================================================================

# 1. Copy this file to .env for development
# 2. Copy this file to .env.production for production builds
# 3. Never commit actual .env files to version control
# 4. Update values according to your deployment environment
# 5. Restart the development server after changing environment variables

