# Emirati Journey Frontend - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# API Configuration
VITE_FLASK_API_BASE_URL=http://localhost:5001
VITE_FLASK_API_URL=http://localhost:5001
REACT_APP_FLASK_API_URL=http://localhost:5001

# Database Configuration (Supabase)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Service Configuration
VITE_GROQ_API_KEY=your_groq_api_key_here

# Enhanced Resume Parsing Configuration
VITE_GROQ_ENHANCED_MODE=true
VITE_GROQ_CONFIDENCE_THRESHOLD=0.8
VITE_GROQ_VALIDATION_THRESHOLD=80
VITE_GROQ_MULTI_PASS_ENABLED=true

# Performance Optimization
VITE_GROQ_CACHE_ENABLED=true
VITE_GROQ_PARALLEL_PROCESSING=true
VITE_GROQ_MAX_RETRIES=3
VITE_GROQ_TIMEOUT_MS=30000

# Monitoring and Analytics
VITE_CONFIDENCE_MONITORING_ENABLED=true
VITE_ACCURACY_LOGGING_ENABLED=true
VITE_PERFORMANCE_TRACKING_ENABLED=true

# Arabic Language Support
VITE_ARABIC_PROCESSING_ENABLED=true
VITE_ARABIC_NORMALIZATION_ENABLED=true
VITE_RTL_TEXT_SUPPORT=true

# Quality Assurance
VITE_VALIDATION_RULES_ENABLED=true
VITE_FIELD_VALIDATION_ENABLED=true
VITE_UAE_FORMAT_VALIDATION=true

# Development and Testing
VITE_DEBUG_MODE=false
VITE_TEST_MODE=false
VITE_MOCK_RESPONSES=false
VITE_ENABLE_DEV_OTP=true               # Show OTP login alongside UAE Pass (set false for production)

# Strategic Framework Integration
VITE_UAE_VISION_2071_ALIGNMENT=true
VITE_D33_ECONOMIC_INTEGRATION=true
VITE_TALENT_2033_SUPPORT=true

# Security and Privacy
VITE_DATA_ENCRYPTION_ENABLED=true
VITE_PRIVACY_COMPLIANCE=true
VITE_AUDIT_LOGGING=true

# API Rate Limiting
VITE_GROQ_RATE_LIMIT_ENABLED=true
VITE_GROQ_REQUESTS_PER_MINUTE=60
VITE_GROQ_BURST_LIMIT=10

# Error Handling
VITE_GRACEFUL_DEGRADATION=true
VITE_FALLBACK_ENABLED=true
VITE_ERROR_RECOVERY=true

# User Experience
VITE_PROGRESS_INDICATORS=true
VITE_CONFIDENCE_DISPLAY=true
VITE_VALIDATION_FEEDBACK=true

# Advanced Features
VITE_MULTI_LANGUAGE_SUPPORT=true
VITE_CULTURAL_INTELLIGENCE=true
VITE_MARKET_ALIGNMENT=true

# Moro Hub Configuration
VITE_MORO_HUB_ENDPOINT=https://api.morohub.com
VITE_MORO_HUB_CDN=https://cdn.morohub.com

