# =============================================================================
# Emirati Pathways — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to version control.
# =============================================================================

# LiveKit
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret-min-32-chars

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=your-minio-user
MINIO_ROOT_PASSWORD=your-minio-password
MINIO_KMS_SECRET_KEY=your-kms-key-name:your-base64-encoded-key

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dghr_prod
DB_USER=emirati_user
DB_PASSWORD=your-db-password
DATABASE_URL=postgresql://emirati_user:your-db-password@localhost:5432/dghr_prod

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
ENCRYPTION_KEY=your-fernet-encryption-key

# AI Services
DASHSCOPE_API_KEY=your-dashscope-api-key
GEMINI_API_KEY=your-gemini-api-key
QWEN_BASE_URL=https://your-approved-endpoint

# Flask
FLASK_ENV=production
FLASK_DEBUG=0

# Redis (required for production multi-node)
REDIS_URL=redis://localhost:6379/0
